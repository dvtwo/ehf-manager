# Shopify App credentials — from Partners Dashboard
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# The public URL of this app (Render URL once deployed)
SHOPIFY_APP_URL=https://your-app.onrender.com

# Comma-separated scopes
SCOPES=read_orders,write_orders

# PostgreSQL connection string (from Render DB)
DATABASE_URL=postgresql://user:password@host:5432/ehf_manager

# Node environment
NODE_ENV=development
